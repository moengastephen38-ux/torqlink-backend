generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String             @id @default(uuid())
  name               String
  email              String             @unique
  password           String
  phone              String?
  role               Role               @default(DRIVER)
  verificationStatus VerificationStatus @default(NOT_SUBMITTED)
  isOnline           Boolean            @default(false)
  pushToken          String?
  laborRate          Float?
  specialization     String[]           @default([])
  toolsOnHand        String[]           @default([])
  bio                String?
  avatarUrl          String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  vehicles             Vehicle[]
  driverRequests       ServiceRequest[]      @relation("DriverRequests")
  mechanicRequests     ServiceRequest[]      @relation("MechanicRequests")
  driverTransactions   Transaction[]         @relation("DriverTransactions")
  mechanicTransactions Transaction[]         @relation("MechanicTransactions")
  wallet               Wallet?
  verification         MechanicVerification?
  partShops            PartShop[]
  carListings          DealershipListing[]
  reviewsGiven         Review[]              @relation("ReviewsGiven")
  reviewsReceived      Review[]              @relation("ReviewsReceived")
  messagesSent         Message[]             @relation("MessagesSent")
}

model Vehicle {
  id          String   @id @default(uuid())
  make        String
  model       String
  year        Int
  plateNumber String   @unique
  color       String?
  createdAt   DateTime @default(now())

  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceRequests ServiceRequest[]
}

model ServiceRequest {
  id          String        @id @default(uuid())
  description String
  issueType   IssueType
  status      RequestStatus @default(PENDING)
  latitude    Float
  longitude   Float
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  driverId String
  driver   User   @relation("DriverRequests", fields: [driverId], references: [id], onDelete: Cascade)

  mechanicId String?
  mechanic   User?   @relation("MechanicRequests", fields: [mechanicId], references: [id])

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  transactions Transaction[]
  review       Review?
  messages     Message[]
}

model Message {
  id        String   @id @default(uuid())
  text      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  serviceRequestId String
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation("MessagesSent", fields: [senderId], references: [id])
}

model Transaction {
  id                 String        @id @default(uuid())
  amount             Float
  commission         Float
  mechanicPayout     Float
  status             PaymentStatus @default(PENDING)
  mpesaReceiptNumber String?
  checkoutRequestId  String?
  phoneNumber        String
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  serviceRequestId String
  serviceRequest   ServiceRequest? @relation(fields: [serviceRequestId], references: [id])

  driverId String
  driver   User   @relation("DriverTransactions", fields: [driverId], references: [id])

  mechanicId String?
  mechanic   User?   @relation("MechanicTransactions", fields: [mechanicId], references: [id])
}

model Wallet {
  id               String   @id @default(uuid())
  balance          Float    @default(0)
  totalEarned      Float    @default(0)
  pendingClearance Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  mechanicId String @unique
  mechanic   User   @relation(fields: [mechanicId], references: [id])
}

model PartShop {
  id                    String             @id @default(uuid())
  name                  String
  description           String?
  latitude              Float
  longitude             Float
  address               String?
  phone                 String?
  subscriptionStatus    SubscriptionStatus @default(INACTIVE)
  subscriptionExpiresAt DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  ownerId String
  owner   User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  parts   PartItem[]
}

model PartItem {
  id            String        @id @default(uuid())
  name          String
  category      String?
  price         Float
  condition     PartCondition @default(NEW)
  compatibility String
  stockStatus   StockStatus   @default(IN_STOCK)
  description   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  shopId String
  shop   PartShop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model DealershipListing {
  id             String           @id @default(uuid())
  title          String
  make           String
  model          String
  year           Int
  price          Float
  condition      VehicleCondition @default(LOCAL_USED)
  transmission   Transmission     @default(AUTOMATIC)
  mileage        Int?
  description    String?
  latitude       Float
  longitude      Float
  status         ListingStatus    @default(AVAILABLE)
  images         String[]         @default([])
  isPaid         Boolean          @default(false)
  listingFeePaid Float?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  sellerId String
  seller   User   @relation(fields: [sellerId], references: [id], onDelete: Cascade)
}

model MechanicVerification {
  id                String             @id @default(uuid())
  certificateUrl    String?
  nationalIdUrl     String?
  businessPermitUrl String?
  workshopPhotoUrl  String?
  yearsExperience   Int?
  specialization    String?
  status            VerificationStatus @default(PENDING)
  rejectionReason   String?
  submittedAt       DateTime           @default(now())
  reviewedAt        DateTime?

  mechanicId String @unique
  mechanic   User   @relation(fields: [mechanicId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  serviceRequestId String         @unique
  serviceRequest   ServiceRequest @relation(fields: [serviceRequestId], references: [id])

  fromUserId String
  fromUser   User   @relation("ReviewsGiven", fields: [fromUserId], references: [id])

  toUserId String
  toUser   User   @relation("ReviewsReceived", fields: [toUserId], references: [id])
}

enum Role {
  DRIVER
  MECHANIC
  SELLER
  ADMIN
}

enum VerificationStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

enum IssueType {
  FLAT_TYRE
  ENGINE_FAILURE
  DEAD_BATTERY
  OUT_OF_FUEL
  OVERHEATING
  ACCIDENT
  OTHER
  FULL_SERVICE
  CAR_WASH
  OIL_CHANGE
  BRAKE_SERVICE
  GENERAL_INSPECTION
}

enum RequestStatus {
  PENDING
  ACCEPTED
  MECHANIC_EN_ROUTE
  RESOLVED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PartCondition {
  NEW
  USED
  REFURBISHED
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
  LOW_STOCK
}

enum VehicleCondition {
  BRAND_NEW
  FOREIGN_USED
  LOCAL_USED
}

enum Transmission {
  AUTOMATIC
  MANUAL
}

enum ListingStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum SubscriptionStatus {
  INACTIVE
  ACTIVE
  EXPIRED
}
