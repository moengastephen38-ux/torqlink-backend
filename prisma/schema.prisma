// ==============================================================================
// TorqLink V2 Complete Unified Schema (61 Models)
// ==============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── GLOBAL ENUMS ──────────────────────────────────────────────────────────────

enum Currency {
  KES
  USD
  EUR
  GBP
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum OrganizationType {
  GARAGE
  PART_SHOP
  DEALERSHIP
  FLEET_OPERATOR
  ENTERPRISE
}

enum VehicleOwnershipType {
  INDIVIDUAL
  ORGANIZATION
}

enum OperatingStatus {
  OPEN
  CLOSED
  MAINTENANCE
  TEMPORARILY_OFFLINE
}

enum EmergencySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EmergencyStatus {
  PENDING
  DISPATCHING
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

enum DispatchStatus {
  ASSIGNED
  EN_ROUTE
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EstimateStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  SUPERSEDED
  EXPIRED
}

enum WorkOrderStatus {
  DRAFT
  DIAGNOSING
  ESTIMATE_PENDING
  APPROVED
  IN_PROGRESS
  QUALITY_CHECK
  READY_FOR_PICKUP
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  VOID
  REFUNDED
}

enum PaymentMethod {
  MPESA
  BANK_TRANSFER
  CARD
  CASH
  WALLETS_ESCROW
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCESSFUL
  FAILED
  REFUNDED
}

enum InventoryMovementType {
  PURCHASE
  SALE
  RETURN_IN
  RETURN_OUT
  TRANSFER
  ADJUSTMENT
  SCRAP
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  RESERVED
  SOLD
  ARCHIVED
}

enum LedgerDirection {
  CREDIT
  DEBIT
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
  DISPUTED
}

enum CommunicationChannel {
  PUSH
  SMS
  EMAIL
  WHATSAPP
}

enum DeliveryStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
}

enum AuditActorType {
  USER
  SYSTEM_CRON
  ADMIN
  WEBHOOK
}

enum FaultCodeSeverity {
  INFO
  WARNING
  CRITICAL
}

// ==============================================================================
// LAYER 1: FOUNDATION SCHEMA (22 MODELS)
// ==============================================================================

// ── 1. GEOGRAPHIC HIERARCHY ───────────────────────────────────────────────────

model Country {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String   @unique
  phoneCode String
  counties  County[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model County {
  id        String     @id @default(uuid())
  countryId String
  country   Country    @relation(fields: [countryId], references: [id], onDelete: Cascade)
  code      String     @unique
  name      String
  towns     Town[]
  locations Location[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([countryId])
}

model Town {
  id        String     @id @default(uuid())
  countyId  String
  county    County     @relation(fields: [countyId], references: [id], onDelete: Cascade)
  name      String
  locations Location[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([countyId])
}

model Location {
  id                String             @id @default(uuid())
  countyId          String?
  county            County?            @relation(fields: [countyId], references: [id], onDelete: SetNull)
  townId            String?
  town              Town?              @relation(fields: [townId], references: [id], onDelete: SetNull)
  
  addressLine1      String
  addressLine2      String?
  postalCode        String?
  latitude          Float
  longitude         Float
  
  garages           Garage[]
  partShops         PartShop[]
  dealerships       Dealership[]
  warehouses        Warehouse[]
  emergencyRequests EmergencyRequest[]

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([latitude, longitude])
}

// ── 2. VEHICLE TAXONOMY ───────────────────────────────────────────────────────

model VehicleMake {
  id        String         @id @default(uuid())
  name      String         @unique
  logoUrl   String?
  models    VehicleModel[]

  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model VehicleModel {
  id          String              @id @default(uuid())
  makeId      String
  make        VehicleMake         @relation(fields: [makeId], references: [id], onDelete: Cascade)
  name        String
  generations VehicleGeneration[]

  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([makeId, name])
}

model VehicleGeneration {
  id           String          @id @default(uuid())
  modelId      String
  model        VehicleModel    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  name         String
  startYear    Int
  endYear      Int?
  trims        VehicleTrim[]
  engines      EngineVariant[]
  partFitments PartFitment[]

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([modelId])
}

model VehicleTrim {
  id           String            @id @default(uuid())
  generationId String
  generation   VehicleGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)
  name         String
  vehicles     Vehicle[]

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([generationId])
}

model EngineVariant {
  id           String            @id @default(uuid())
  generationId String
  generation   VehicleGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)
  code         String
  displacement Decimal           @db.Decimal(3, 1)
  fuelType     String
  horsepower   Int?
  vehicles     Vehicle[]
  partFitments PartFitment[]

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([generationId])
}

// ── 3. USER IDENTITY & PROFILES ───────────────────────────────────────────────

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  phoneNumber         String               @unique
  passwordHash        String
  firstName           String
  lastName            String
  avatarUrl           String?
  
  driverProfile       DriverProfile?
  mechanicProfile     MechanicProfile?
  sellerProfile       SellerProfile?
  adminProfile        AdminProfile?
  
  organizationMembers OrganizationMember[]
  ownedVehicles       Vehicle[]
  emergencyRequests   EmergencyRequest[]
  wallet              Wallet?
  
  conversationMembers ConversationMember[]
  sentMessages        Message[]
  notifications       Notification[]
  uploadedMedia       Media[]

  version             Int                  @default(1)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?

  @@index([email])
  @@index([phoneNumber])
}

model DriverProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  nationalId         String?            @unique
  verificationStatus VerificationStatus @default(UNVERIFIED)

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model MechanicProfile {
  id                  String              @id @default(uuid())
  userId              String              @unique
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialties         String[]
  yearsOfExperience   Int                 @default(0)
  verificationStatus  VerificationStatus  @default(UNVERIFIED)
  
  dispatches          Dispatch[]
  workOrders          WorkOrder[]
  diagnosticSessions DiagnosticSession[]

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
}

model SellerProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName       String?
  verificationStatus VerificationStatus @default(UNVERIFIED)

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model AdminProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  department String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── 4. ORGANIZATION & RBAC ───────────────────────────────────────────────────

model Organization {
  id           String                @id @default(uuid())
  name         String
  type         OrganizationType      @default(GARAGE)
  taxPin       String?               @unique
  
  settings     OrganizationSettings?
  members      OrganizationMember[]
  roles        Role[]
  vehicles     Vehicle[]
  garages      Garage[]
  partShops    PartShop[]
  dealerships  Dealership[]
  warehouses   Warehouse[]
  estimates    Estimate[]
  workOrders   WorkOrder[]
  invoices     Invoice[]
  wallet       Wallet?

  version      Int                   @default(1)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  deletedAt    DateTime?

  @@index([name])
}

model OrganizationSettings {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  currency       Currency     @default(KES)
  taxRate        Decimal      @default(16.00) @db.Decimal(5, 2)
  autoApproveEst Boolean      @default(false)

  updatedAt      DateTime     @updatedAt
}

model OrganizationMember {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  memberRoles    MemberRole[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, userId])
}

model Role {
  id              String           @id @default(uuid())
  organizationId  String?
  organization    Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  name            String
  isSystem        Boolean          @default(false)
  
  rolePermissions RolePermission[]
  memberRoles     MemberRole[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([organizationId, name])
}

model Permission {
  id              String           @id @default(uuid())
  key             String           @unique
  description     String?
  
  rolePermissions RolePermission[]

  createdAt       DateTime         @default(now())
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model MemberRole {
  id       String             @id @default(uuid())
  memberId String
  member   OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  
  roleId   String
  role     Role               @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([memberId, roleId])
}

// ── 5. SHARED MEDIA VAULT ────────────────────────────────────────────────────

model Media {
  id           String    @id @default(uuid())
  url          String
  mimeType     String
  fileSizeBytes Int
  
  uploadedById String?
  uploadedBy   User?     @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt    DateTime  @default(now())
}

// ==============================================================================
// LAYER 2: OPERATIONAL SCHEMA (25 MODELS)
// ==============================================================================

// ── 1. FLEET & CUSTOMER VEHICLES ─────────────────────────────────────────────

model Vehicle {
  id                   String                 @id @default(uuid())
  ownerType            VehicleOwnershipType   @default(INDIVIDUAL)
  
  ownerUserId          String?
  ownerUser            User?                  @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  organizationId       String?
  organization         Organization?          @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  
  trimId               String
  trim                 VehicleTrim            @relation(fields: [trimId], references: [id])
  engineVariantId      String?
  engineVariant        EngineVariant?         @relation(fields: [engineVariantId], references: [id])
  
  plateNumber          String                 @unique
  vin                  String?                @unique
  manufactureYear      Int
  color                String?
  currentMileageKm     Int                    @default(0)
  
  emergencyRequests    EmergencyRequest[]
  workOrders           WorkOrder[]
  listings             VehicleListing[]
  diagnosticSessions   DiagnosticSession[]
  maintenancePredictions MaintenancePrediction[]
  
  version              Int                    @default(1)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  deletedAt            DateTime?
  createdById          String?
  updatedById          String?

  @@index([plateNumber])
  @@index([vin])
  @@index([ownerUserId])
  @@index([organizationId])
}

// ── 2. PROVIDERS & WAREHOUSE FACILITIES ───────────────────────────────────────

model Garage {
  id              String          @id @default(uuid())
  organizationId  String
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  locationId      String
  location        Location        @relation(fields: [locationId], references: [id])
  
  name            String
  operatingStatus OperatingStatus @default(OPEN)
  bayCapacity     Int             @default(4)
  hourlyLaborRate Decimal         @default(1500.00) @db.Decimal(10, 2)
  
  warehouses      Warehouse[]
  workOrders      WorkOrder[]
  dispatches      Dispatch[]
  
  version         Int             @default(1)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?
  createdById     String?
  updatedById     String?

  @@index([organizationId])
  @@index([locationId])
}

model PartShop {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  locationId     String
  location       Location     @relation(fields: [locationId], references: [id])
  
  name           String
  warehouses     Warehouse[]
  
  version        Int          @default(1)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  createdById    String?
  updatedById    String?

  @@index([organizationId])
}

model Dealership {
  id             String           @id @default(uuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  locationId     String
  location       Location         @relation(fields: [locationId], references: [id])
  
  name           String
  listings       VehicleListing[]
  
  version        Int              @default(1)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?
  createdById    String?
  updatedById    String?

  @@index([organizationId])
}

model Warehouse {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  garageId       String?
  garage         Garage?      @relation(fields: [garageId], references: [id], onDelete: SetNull)
  partShopId     String?
  partShop       PartShop?    @relation(fields: [partShopId], references: [id], onDelete: SetNull)
  
  locationId     String
  location       Location     @relation(fields: [locationId], references: [id])
  
  name           String
  code           String       @unique
  
  shelves        Shelf[]
  
  version        Int          @default(1)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  createdById    String?
  updatedById    String?

  @@index([organizationId])
}

model Shelf {
  id          String        @id @default(uuid())
  warehouseId String
  warehouse   Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  
  code        String
  bins        BinLocation[]
  
  version     Int           @default(1)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  @@unique([warehouseId, code])
}

model BinLocation {
  id             String          @id @default(uuid())
  shelfId        String
  shelf          Shelf           @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  
  code           String
  inventoryItems InventoryItem[]
  
  version        Int             @default(1)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?

  @@unique([shelfId, code])
}

// ── 3. EMERGENCY ROADSIDE DISPATCH ENGINE ─────────────────────────────────────

model EmergencyRequest {
  id          String            @id @default(uuid())
  reqNumber   String            @unique
  
  customerId  String
  customer    User              @relation(fields: [customerId], references: [id])
  
  vehicleId   String
  vehicle     Vehicle           @relation(fields: [vehicleId], references: [id])
  
  locationId  String
  location    Location          @relation(fields: [locationId], references: [id])
  
  severity    EmergencySeverity @default(MEDIUM)
  status      EmergencyStatus   @default(PENDING)
  description String
  
  dispatches  Dispatch[]
  escrowHolds EscrowHold[]
  
  version     Int               @default(1)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?
  createdById String?
  updatedById String?

  @@index([reqNumber])
  @@index([status])
  @@index([customerId])
}

model Dispatch {
  id                 String           @id @default(uuid())
  emergencyRequestId String
  emergencyRequest   EmergencyRequest @relation(fields: [emergencyRequestId], references: [id], onDelete: Cascade)
  
  assignedMechanicId String?
  assignedMechanic   MechanicProfile? @relation(fields: [assignedMechanicId], references: [id])
  
  garageId           String?
  garage             Garage?          @relation(fields: [garageId], references: [id])
  
  status             DispatchStatus   @default(ASSIGNED)
  acceptedAt         DateTime?
  enRouteAt          DateTime?
  arrivedAt          DateTime?
  completedAt        DateTime?
  
  workOrders         WorkOrder[]
  
  version            Int              @default(1)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?

  @@index([emergencyRequestId])
  @@index([assignedMechanicId])
  @@index([status])
}

// ── 4. WORK ORDERS & SEPARATED FINANCIAL DOCUMENTS ────────────────────────────

model Estimate {
  id             String         @id @default(uuid())
  estNumber      String         @unique
  revision       Int            @default(1)
  
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id])
  
  workOrderId    String?
  workOrder      WorkOrder?     @relation(fields: [workOrderId], references: [id])
  
  status         EstimateStatus @default(DRAFT)
  subtotal       Decimal        @default(0.00) @db.Decimal(18, 2)
  taxAmount      Decimal        @default(0.00) @db.Decimal(18, 2)
  totalAmount    Decimal        @default(0.00) @db.Decimal(18, 2)
  currency       Currency       @default(KES)
  
  items          EstimateItem[]
  
  version        Int            @default(1)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  createdById    String?
  updatedById    String?

  @@index([estNumber])
  @@index([workOrderId])
}

model EstimateItem {
  id          String   @id @default(uuid())
  estimateId  String
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(18, 2)
  totalPrice  Decimal  @db.Decimal(18, 2)
  isPart      Boolean  @default(false)
  partItemId  String?
  
  createdAt   DateTime @default(now())
}

model WorkOrder {
  id                 String          @id @default(uuid())
  woNumber           String          @unique
  
  organizationId     String
  organization       Organization    @relation(fields: [organizationId], references: [id])
  
  garageId           String?
  garage             Garage?         @relation(fields: [garageId], references: [id])
  
  dispatchId         String?
  dispatch           Dispatch?       @relation(fields: [dispatchId], references: [id])
  
  vehicleId          String
  vehicle            Vehicle         @relation(fields: [vehicleId], references: [id])
  
  assignedMechanicId String?
  assignedMechanic   MechanicProfile? @relation(fields: [assignedMechanicId], references: [id])
  
  status             WorkOrderStatus @default(DRAFT)
  customerNotes      String?
  technicianNotes    String?
  
  estimates          Estimate[]
  items              WorkOrderItem[]
  invoices           Invoice[]
  escrowHolds        EscrowHold[]
  
  version            Int             @default(1)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  deletedAt          DateTime?
  createdById        String?
  updatedById        String?

  @@index([woNumber])
  @@index([status])
  @@index([vehicleId])
}

model WorkOrderItem {
  id          String    @id @default(uuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  
  description String
  quantity    Int       @default(1)
  unitPrice   Decimal   @db.Decimal(18, 2)
  totalPrice  Decimal   @db.Decimal(18, 2)
  isPart      Boolean   @default(false)
  partItemId  String?
  
  createdAt   DateTime  @default(now())
}

model Invoice {
  id             String        @id @default(uuid())
  invNumber      String        @unique
  
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  
  workOrderId    String?
  workOrder      WorkOrder?    @relation(fields: [workOrderId], references: [id])
  
  status         InvoiceStatus @default(DRAFT)
  
  subtotal       Decimal       @default(0.00) @db.Decimal(18, 2)
  taxRate        Decimal       @default(16.00) @db.Decimal(5, 2)
  taxAmount      Decimal       @default(0.00) @db.Decimal(18, 2)
  withholdingTax Decimal       @default(0.00) @db.Decimal(18, 2)
  discountAmount Decimal       @default(0.00) @db.Decimal(18, 2)
  totalAmount    Decimal       @default(0.00) @db.Decimal(18, 2)
  currency       Currency      @default(KES)
  exchangeRate   Decimal       @default(1.0000) @db.Decimal(10, 4)
  
  items          InvoiceItem[]
  payments       Payment[]
  
  version        Int           @default(1)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  createdById    String?
  updatedById    String?

  @@index([invNumber])
  @@index([status])
  @@index([workOrderId])
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(18, 2)
  totalPrice  Decimal  @db.Decimal(18, 2)
  
  createdAt   DateTime @default(now())
}

model Payment {
  id                 String              @id @default(uuid())
  payNumber          String              @unique
  
  invoiceId          String?
  invoice            Invoice?            @relation(fields: [invoiceId], references: [id])
  
  amount             Decimal             @db.Decimal(18, 2)
  currency           Currency            @default(KES)
  method             PaymentMethod       @default(MPESA)
  status             PaymentStatus       @default(PENDING)
  
  externalReceiptRef String?             @unique
  
  ledgerTransactions LedgerTransaction[]
  
  version            Int                 @default(1)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  createdById        String?
  updatedById        String?

  @@index([payNumber])
  @@index([externalReceiptRef])
  @@index([status])
}

// ── 5. MARKETPLACE & IMMUTABLE ERP INVENTORY ──────────────────────────────────

model PartItem {
  id             String          @id @default(uuid())
  sku            String          @unique
  oemNumber      String?
  name           String
  brand          String?
  description    String?
  
  inventoryItems InventoryItem[]
  fitments       PartFitment[]
  
  version        Int             @default(1)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  createdById    String?
  updatedById    String?

  @@index([sku])
  @@index([oemNumber])
}

model PartFitment {
  id              String             @id @default(uuid())
  partItemId      String
  partItem        PartItem           @relation(fields: [partItemId], references: [id], onDelete: Cascade)
  
  generationId    String?
  generation      VehicleGeneration? @relation(fields: [generationId], references: [id])
  
  engineVariantId String?
  engineVariant   EngineVariant?     @relation(fields: [engineVariantId], references: [id])

  @@unique([partItemId, generationId, engineVariantId])
}

model InventoryItem {
  id             String              @id @default(uuid())
  partItemId     String
  partItem       PartItem            @relation(fields: [partItemId], references: [id])
  
  binLocationId  String
  binLocation    BinLocation         @relation(fields: [binLocationId], references: [id])
  
  unitCost       Decimal             @db.Decimal(18, 2)
  sellingPrice   Decimal             @db.Decimal(18, 2)
  
  balance        InventoryBalance?
  movements      InventoryMovement[]
  
  version        Int                 @default(1)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?

  @@index([partItemId])
  @@index([binLocationId])
}

model InventoryBalance {
  id                String        @id @default(uuid())
  inventoryItemId   String        @unique
  inventoryItem     InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  
  quantityOnHand    Int           @default(0)
  quantityReserved  Int           @default(0)
  quantityAvailable Int           @default(0)
  
  version           Int           @default(1)
  updatedAt         DateTime      @updatedAt
}

model InventoryMovement {
  id                 String                @id @default(uuid())
  inventoryItemId    String
  inventoryItem      InventoryItem         @relation(fields: [inventoryItemId], references: [id])
  
  type               InventoryMovementType
  quantity           Int
  previousOnHand     Int
  newOnHand          Int
  
  referenceDocNumber String?
  
  createdAt          DateTime              @default(now())
  createdById        String?

  @@index([inventoryItemId])
  @@index([type])
}

model VehicleListing {
  id            String        @id @default(uuid())
  listingNumber String        @unique
  
  dealershipId  String
  dealership    Dealership    @relation(fields: [dealershipId], references: [id])
  
  vehicleId     String
  vehicle       Vehicle       @relation(fields: [vehicleId], references: [id])
  
  price         Decimal       @db.Decimal(18, 2)
  currency      Currency      @default(KES)
  status        ListingStatus @default(DRAFT)
  description   String?
  
  version       Int           @default(1)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?
  createdById   String?
  updatedById   String?

  @@index([listingNumber])
  @@index([status])
}

// ── 6. FINANCIAL ESCROW & WALLET LEDGER ───────────────────────────────────────

model Wallet {
  id               String              @id @default(uuid())
  organizationId   String?             @unique
  organization     Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  userId           String?             @unique
  user             User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  availableBalance Decimal             @default(0.00) @db.Decimal(18, 2)
  escrowBalance    Decimal             @default(0.00) @db.Decimal(18, 2)
  currency         Currency            @default(KES)
  
  escrowHolds      EscrowHold[]
  transactions     LedgerTransaction[]
  
  version          Int                 @default(1)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  deletedAt        DateTime?

  @@index([organizationId])
  @@index([userId])
}

model EscrowHold {
  id                 String            @id @default(uuid())
  walletId           String
  wallet             Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  
  emergencyRequestId String?
  emergencyRequest   EmergencyRequest? @relation(fields: [emergencyRequestId], references: [id])
  
  workOrderId        String?
  workOrder          WorkOrder?        @relation(fields: [workOrderId], references: [id])
  
  amount             Decimal           @db.Decimal(18, 2)
  currency           Currency          @default(KES)
  status             EscrowStatus      @default(HELD)
  
  version            Int               @default(1)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?

  @@index([walletId])
  @@index([status])
}

model LedgerTransaction {
  id            String          @id @default(uuid())
  walletId      String
  wallet        Wallet          @relation(fields: [walletId], references: [id])
  
  paymentId     String?
  payment       Payment?        @relation(fields: [paymentId], references: [id])
  
  direction     LedgerDirection
  amount        Decimal         @db.Decimal(18, 2)
  currency      Currency        @default(KES)
  balanceBefore Decimal         @db.Decimal(18, 2)
  balanceAfter  Decimal         @db.Decimal(18, 2)
  
  description   String
  
  createdAt     DateTime        @default(now())

  @@index([walletId])
  @@index([direction])
}

// ==============================================================================
// LAYER 3: PLATFORM SERVICES SCHEMA (14 MODELS)
// ==============================================================================

// ── 1. MULTI-PARTY CHAT & MESSAGING ───────────────────────────────────────────

model Conversation {
  id                 String               @id @default(uuid())
  title              String?
  
  emergencyRequestId String?
  workOrderId        String?
  
  participants       ConversationMember[]
  messages           Message[]
  
  version            Int                  @default(1)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  deletedAt          DateTime?
  createdById        String?
  updatedById        String?

  @@index([emergencyRequestId])
  @@index([workOrderId])
}

model ConversationMember {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id              String       @id @default(uuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  senderId        String
  sender          User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  content         String
  mediaUrl        String?
  isSystemMessage Boolean      @default(false)
  
  version         Int          @default(1)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?

  @@index([conversationId])
  @@index([senderId])
}

// ── 2. NOTIFICATIONS & MULTI-CHANNEL DELIVERIES ───────────────────────────────

model Notification {
  id          String                 @id @default(uuid())
  recipientId String
  recipient   User                   @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  
  title       String
  body        String
  data        Json?
  isRead      Boolean                @default(false)
  readAt      DateTime?
  
  deliveries  NotificationDelivery[]
  
  version     Int                    @default(1)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  deletedAt   DateTime?

  @@index([recipientId])
  @@index([isRead])
}

model NotificationDelivery {
  id             String               @id @default(uuid())
  notificationId String
  notification   Notification         @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  
  channel        CommunicationChannel
  status         DeliveryStatus       @default(PENDING)
  attempts       Int                  @default(0)
  externalRef    String?
  failureReason  String?
  
  sentAt         DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([notificationId])
  @@index([channel, status])
}

// ── 3. DOMAIN EVENTS (LIGHTWEIGHT EVENT SOURCING) ─────────────────────────────

model DomainEvent {
  id            String    @id @default(uuid())
  eventName     String
  aggregateType String
  aggregateId   String
  
  payload       Json
  published     Boolean   @default(false)
  publishedAt   DateTime?
  
  occurredAt    DateTime  @default(now())

  @@index([eventName])
  @@index([aggregateType, aggregateId])
  @@index([published])
}

// ── 4. INDEPENDENT SEARCH ENGINE INDEX ────────────────────────────────────────

model SearchDocument {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  
  title      String
  body       String
  keywords   String[]
  
  latitude   Float?
  longitude  Float?
  county     String?
  
  version    Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([entityType, entityId])
  @@index([entityType])
  @@index([latitude, longitude])
}

// ── 5. AI DIAGNOSTICS & TELEMETRY ENGINE ──────────────────────────────────────

model DiagnosticSession {
  id                String                @id @default(uuid())
  sessionNumber     String                @unique
  
  vehicleId         String
  vehicle           Vehicle               @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  
  mechanicProfileId String?
  mechanicProfile   MechanicProfile?      @relation(fields: [mechanicProfileId], references: [id], onDelete: SetNull)
  
  symptomsReported  String[]
  audioRecordingUrl String?
  
  faultCodes        DiagnosticFaultCode[]
  recommendations   AIRecommendation[]
  
  version           Int                   @default(1)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  deletedAt         DateTime?
  createdById       String?

  @@index([sessionNumber])
  @@index([vehicleId])
}

model FaultCode {
  id          String                @id @default(uuid())
  code        String                @unique
  system      String
  description String
  severity    FaultCodeSeverity     @default(WARNING)
  
  sessions    DiagnosticFaultCode[]
  
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@index([code])
}

model DiagnosticFaultCode {
  id                  String            @id @default(uuid())
  diagnosticSessionId String
  diagnosticSession   DiagnosticSession @relation(fields: [diagnosticSessionId], references: [id], onDelete: Cascade)
  
  faultCodeId         String
  faultCode           FaultCode         @relation(fields: [faultCodeId], references: [id], onDelete: Cascade)
  
  detectedAt          DateTime          @default(now())

  @@unique([diagnosticSessionId, faultCodeId])
}

model AIRecommendation {
  id                  String            @id @default(uuid())
  diagnosticSessionId String
  diagnosticSession   DiagnosticSession @relation(fields: [diagnosticSessionId], references: [id], onDelete: Cascade)
  
  suggestedAction     String
  confidenceScore     Decimal           @db.Decimal(5, 4)
  suggestedPartSkus   String[]
  estimatedLaborHours Decimal           @db.Decimal(4, 2)
  
  createdAt           DateTime          @default(now())

  @@index([diagnosticSessionId])
}

model VINDecode {
  id          String   @id @default(uuid())
  vin         String   @unique
  rawResponse Json
  parsedSpecs Json
  
  createdAt   DateTime @default(now())

  @@index([vin])
}

model MaintenancePrediction {
  id                   String    @id @default(uuid())
  vehicleId            String
  vehicle              Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  
  predictedComponent   String
  predictedFailureKm   Int
  confidenceScore      Decimal   @db.Decimal(5, 4)
  recommendedServiceAt DateTime?
  
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([vehicleId])
}

// ── 6. AUDIT ENGINE & PLATFORM GOVERNANCE ─────────────────────────────────────

model AuditLog {
  id         String         @id @default(uuid())
  actorId    String?
  actorType  AuditActorType @default(USER)
  
  action     String
  entityName String
  entityId   String
  
  before     Json?
  after      Json?
  
  ipAddress  String?
  userAgent  String?
  
  createdAt  DateTime       @default(now())

  @@index([entityName, entityId])
  @@index([actorId])
  @@index([action])
}