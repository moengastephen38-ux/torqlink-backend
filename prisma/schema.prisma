 generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

 model User {
  id               String           @id @default(uuid())
  name             String
  email            String           @unique
  password         String
  phone            String?
  role             Role             @default(DRIVER)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  vehicles         Vehicle[]
  driverRequests   ServiceRequest[] @relation("DriverRequests")
  mechanicRequests ServiceRequest[] @relation("MechanicRequests")
}

model Vehicle {
  id              String           @id @default(uuid())
  make            String
  model           String
  year            Int
  plateNumber     String           @unique
  color           String?
  createdAt       DateTime         @default(now())

  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceRequests ServiceRequest[]
}

enum Role {
  DRIVER
  MECHANIC
  ADMIN
}

model ServiceRequest {
  id               String        @id @default(uuid())
  description      String
  issueType        IssueType
  status           RequestStatus @default(PENDING)
  latitude         Float
  longitude        Float
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  driverId         String
  driver           User          @relation("DriverRequests", fields: [driverId], references: [id], onDelete: Cascade)

  mechanicId       String?
  mechanic         User?         @relation("MechanicRequests", fields: [mechanicId], references: [id])

  vehicleId        String
  vehicle          Vehicle       @relation(fields: [vehicleId], references: [id])
}

enum IssueType {
  FLAT_TYRE
  ENGINE_FAILURE
  DEAD_BATTERY
  OUT_OF_FUEL
  OVERHEATING
  ACCIDENT
  OTHER
}

enum RequestStatus {
  PENDING
  ACCEPTED
  MECHANIC_EN_ROUTE
  RESOLVED
  CANCELLED
}